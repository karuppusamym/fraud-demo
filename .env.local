# Risk band for mock LLM and fraud signals.
# Controls which routing path the fraud workflow takes:
#   low      → auto_approve_transaction     (no HITL)
#   medium   → challenge_customer           (no HITL)
#   high     → freeze → analyst_review_decision  (HITL ✓)
#   critical → freeze_and_escalate → compliance_officer_sar_decision  (HITL ✓)
MOCK_RISK_BAND=high
